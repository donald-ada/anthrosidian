{
  "description": "Inject a minimal knowledge-base pointer on session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-$PWD}}/hooks/session-start.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
